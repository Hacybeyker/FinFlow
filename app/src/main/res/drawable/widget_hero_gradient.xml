<?xml version="1.0" encoding="utf-8"?>
<!-- A very subtle diagonal gradient across the brand primary, close enough to a solid fill that
     it never competes with the amounts, just gives the widget a little depth at the edges. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#7B50F5"
        android:endColor="#5F36D7" />
</shape>
