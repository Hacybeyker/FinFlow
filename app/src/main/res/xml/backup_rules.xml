<?xml version="1.0" encoding="utf-8"?><!--
   Applies to devices on API 30 and below (API 31+ reads data_extraction_rules.xml).

   The SQLCipher database and the encrypted prefs holding its passphrase are excluded because they
   are only decryptable with the Android Keystore MasterKey of THIS device: the Keystore never
   leaves the device, so a restored copy is unreadable and would crash the app at startup.
-->
<full-backup-content>
    <exclude domain="database" path="finflow.db" />
    <exclude domain="database" path="finflow.db-wal" />
    <exclude domain="database" path="finflow.db-shm" />
    <exclude domain="sharedpref" path="finflow_secure_prefs.xml" />
</full-backup-content>
