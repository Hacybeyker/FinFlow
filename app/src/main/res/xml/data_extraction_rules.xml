<?xml version="1.0" encoding="utf-8"?><!--
   Applies to devices on API 31+ (older devices read backup_rules.xml).

   The SQLCipher database and the encrypted prefs holding its passphrase are excluded from both
   cloud backup and device-to-device transfer: they are only decryptable with the Android Keystore
   MasterKey of THIS device, which never leaves it, so a restored/transferred copy is unreadable
   and would crash the app at startup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="finflow.db" />
        <exclude domain="database" path="finflow.db-wal" />
        <exclude domain="database" path="finflow.db-shm" />
        <exclude domain="sharedpref" path="finflow_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="finflow.db" />
        <exclude domain="database" path="finflow.db-wal" />
        <exclude domain="database" path="finflow.db-shm" />
        <exclude domain="sharedpref" path="finflow_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
