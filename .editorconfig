# EditorConfig — base de estilo para Kotlin/Compose. ktlint lo lee directamente.
# https://editorconfig.org/  ·  https://ktlint.github.io/
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# Estilo: ktlint_official | intellij_idea | android_studio
ktlint_code_style = android_studio
max_line_length = 120
# Jetpack Compose: las funciones @Composable/@Preview usan PascalCase.
# En vez de desactivar la regla de naming, se le indica que ignore esas
# anotaciones (ktlint >= 1.0). El resto de funciones se siguen validando.
ktlint_function_naming_ignore_when_annotated_with = Composable,Preview
# Los ficheros de Compose suelen tener varias funciones top-level (Theme.kt,
# Color.kt...), por lo que la regla de nombre-de-fichero se relaja.
ktlint_standard_filename = disabled
# Sin coma final (estetica): ktlint la elimina y la prohibe.
ij_kotlin_allow_trailing_comma = false
ij_kotlin_allow_trailing_comma_on_call_site = false
# Prohibe TODOS los wildcard imports (import x.*): ningun paquete exento.
# Lo aplica ktlint al construir (ktlintCheck), no solo el editor.
ij_kotlin_packages_to_use_import_on_demand = unset
# Evita que Android Studio/IntelliJ colapse imports en wildcard al escribir
# (umbral altisimo = nunca usar star import). Complementa la regla de ktlint.
ij_kotlin_name_count_to_use_star_import = 2147483647
ij_kotlin_name_count_to_use_star_import_for_members = 2147483647

[*.{yml,yaml,json,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
